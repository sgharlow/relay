# =============================================================================
# Relay H0 MVP — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Aurora DSQL — Multi-Region Active-Active
# Generated by scripts/provision-dsql.sh
# See docs/aws-setup.md for provisioning instructions.
# -----------------------------------------------------------------------------
DSQL_PRIMARY_ENDPOINT=
DSQL_SECONDARY_ENDPOINT=
DSQL_CLUSTER_ARN=

# Set to "true" to route all DB traffic to the secondary region (failover demo)
DSQL_USE_SECONDARY=

# -----------------------------------------------------------------------------
# AWS KMS — Envelope Encryption
# The CMK used to wrap per-item AES-GCM-256 data keys.
# -----------------------------------------------------------------------------
KMS_KEY_ID=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# JWT secret for recipient scoped tokens (HS256)
# Generate with: openssl rand -base64 32
RECIPIENT_JWT_SECRET=

# JWT secret for verifier scoped confirmation tokens (HS256)
# Generate with: openssl rand -base64 32
VERIFIER_JWT_SECRET=

# -----------------------------------------------------------------------------
# Vercel Cron — Heartbeat evaluator
# Shared secret validated in POST /api/cron/heartbeat
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# AI Agents — OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Email Delivery — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# -----------------------------------------------------------------------------
# AWS Credentials (local dev only — use IAM role in production)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
